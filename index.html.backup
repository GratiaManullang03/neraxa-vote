            <!-- CONFIRMATION -->
            <div class="confirmation" id="confirmation">
                <div class="conf-check">✓</div>
                <h3 class="conf-title">Your vote is in!</h3>
                <p class="conf-sub" id="confSub">
                    Thank you for helping shape Neraxa's future.
                </p>
            </div>

            <!-- RESULTS -->
            <section class="results-section" id="resultsSection">
                <div class="section-eyebrow">Step 02 — Results</div>
                <h2 class="section-title">Community Preferences</h2>
                <p class="section-sub">
                    The top 3 highlighted styles will be developed and shipped
                    in Neraxa.
                </p>
                <div class="results-list" id="resultsList"></div>
            </section>

            <!-- FOOTER -->
            <footer class="footer">
                <div class="footer-left">
                    <div class="footer-logo">N</div>
